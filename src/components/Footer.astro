---
import { t, type Lang } from '../i18n/utils';

interface Props {
    lang?: Lang;
}

const { lang = 'es' } = Astro.props;
---
<footer class="footer">
    <div class="container footer-content">
        <div class="footer-left">
            <span>{t('footer.copyright', lang)}</span>
            <a href="https://diego303.github.io/oss-ecosystem-project/" target="_blank" class="footer-oss-link">OSS Ecosystem Project</a>
        </div>
        <div class="footer-right">
            <span class="footer-tagline">{t('footer.tagline', lang)}</span> <span class="footer-claude">{t('footer.createdWith', lang)} <a href="https://claude.ai/claude-code" target="_blank" class="claude-link">Claude Code</a></span>
        </div>
    </div>
</footer>

<style>
    .footer {
        margin-top: auto;
        border-top: 2px solid var(--arch-ink);
        background-color: var(--arch-surface);
        padding: 2.5rem 0;
        z-index: 10;
        position: relative;
    }

    .footer-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        justify-content: space-between;
        color: var(--arch-ink-light);
        font-size: 0.875rem;
        font-weight: 500;
    }

    @media (min-width: 768px) {
        .footer-content {
            flex-direction: row;
            gap: 0;
        }
    }

    .footer-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .footer-oss-link {
        color: var(--arch-brick);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s;
    }

    .footer-oss-link:hover {
        color: var(--arch-brick-light);
    }

    .footer-right {
        display: flex;
        align-items: center;
        gap: 0.375rem;
    }

    .footer-tagline {
        color: var(--arch-ink);
        font-weight: 700;
    }

    .footer-claude {
        color: var(--arch-ink-light);
        font-size: 0.8125rem;
    }

    .claude-link {
        color: var(--arch-brick);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s;
    }

    .claude-link:hover {
        color: var(--arch-brick-light);
    }
</style>
